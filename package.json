{
  "name": "agency",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "GitHub-native registry for Squad manifests.",
  "scripts": {
    "dev": "npm run build:registry && astro dev",
    "build": "npm run build:registry && astro build",
    "preview": "astro preview",
    "build:registry": "node tooling/scripts/build-registry.mjs",
    "validate": "node tooling/scripts/validate-squads.mjs",
    "test": "node --test tooling/tests/registry.test.mjs",
    "test:visual": "npm run build && node --test tooling/tests/visual-acceptance.test.mjs"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "~4.1.18",
    "astro": "~5.18.1",
    "playwright": "^1.58.2",
    "puppeteer": "^24.39.1",
    "tailwindcss": "~4.1.18"
  }
}
