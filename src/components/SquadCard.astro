---
const { squad, index } = Astro.props;

const searchText = [
  squad.name,
  squad.tagline,
  squad.summary,
  squad.howTheyWork,
  squad.sourceLabel,
  squad.focus.join(' '),
  squad.members.map((member) => `${member.name} ${member.role} ${member.expertise.join(' ')}`).join(' '),
]
  .join(' ')
  .toLowerCase();

const statusTone =
  squad.status === 'live'
    ? 'border border-green-200 bg-green-50 text-green-700'
    : squad.status === 'building'
      ? 'border border-squad-200 bg-squad-50 text-squad-700'
      : 'border border-surface-200 bg-surface-100 text-surface-600';

const statusLabel = squad.status
  .split('-')
  .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
  .join(' ');
---

<article
  class="group flex h-full cursor-pointer flex-col rounded-lg border border-surface-200 bg-white p-4 transition hover:border-surface-300 hover:shadow-sm focus-visible:border-squad-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-squad-500/30"
  data-index={index}
  data-search={searchText}
  data-status={squad.status}
  data-focus={squad.focus.join(',')}
  data-squad-card
  tabindex="0"
>
  <div class="mb-3 flex items-center gap-2">
    <span class={`inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium ${statusTone}`}>
      {statusLabel}
    </span>
    <span class="text-xs text-surface-400">{squad.sourceLabel}</span>
  </div>

  <h2 class="mb-1 text-lg font-semibold tracking-tight text-surface-900">{squad.name}</h2>
  <p class="mb-3 text-sm leading-6 text-surface-600">{squad.tagline}</p>

  <ul class="mb-4 flex flex-wrap gap-1.5">
    {squad.focus.slice(0, 3).map((focus) => (
      <li class="rounded-md border border-surface-200 bg-surface-50 px-2 py-0.5 text-xs text-surface-600">{focus}</li>
    ))}
    {squad.focus.length > 3 && (
      <li class="rounded-md border border-surface-200 bg-surface-50 px-2 py-0.5 text-xs text-surface-400">+{squad.focus.length - 3}</li>
    )}
  </ul>

  <div class="mt-auto flex items-center justify-between border-t border-surface-100 pt-3 text-sm text-surface-500">
    <span>{squad.members.length} member{squad.members.length === 1 ? '' : 's'}</span>
    <a
      class="font-medium text-squad-600 transition hover:text-squad-700 hover:underline"
      href={squad.source.repository}
      rel="noopener"
      target="_blank"
    >
      View →
    </a>
  </div>
</article>
