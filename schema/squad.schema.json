{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sbroenne.github.io/agency/schema/squad.schema.json",
  "title": "Agency squad manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "specVersion",
    "id",
    "slug",
    "name",
    "status",
    "tagline",
    "summary",
    "mission",
    "focus",
    "source",
    "team"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "specVersion": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80
    },
    "status": {
      "type": "string",
      "enum": ["live", "building", "prototype"]
    },
    "tagline": {
      "type": "string",
      "minLength": 10,
      "maxLength": 140
    },
    "summary": {
      "type": "string",
      "minLength": 30,
      "maxLength": 600
    },
    "mission": {
      "type": "string",
      "minLength": 30,
      "maxLength": 600
    },
    "focus": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 40
      },
      "uniqueItems": true
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "directory"],
      "properties": {
        "repository": {
          "type": "string",
          "format": "uri"
        },
        "directory": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "import": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["manual", "upstream-sync", "fork-sync"]
            },
            "path": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "ref": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100
            }
          }
        }
      }
    },
    "links": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "url"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "team": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "members"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80
        },
        "members": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "role", "expertise"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 2,
                "maxLength": 80
              },
              "role": {
                "type": "string",
                "minLength": 2,
                "maxLength": 80
              },
              "expertise": {
                "type": "array",
                "minItems": 1,
                "maxItems": 8,
                "items": {
                  "type": "string",
                  "minLength": 2,
                  "maxLength": 40
                },
                "uniqueItems": true
              },
              "github": {
                "type": "string",
                "pattern": "^@[A-Za-z0-9-]+$"
              }
            }
          }
        }
      }
    }
  }
}
